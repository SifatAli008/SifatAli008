# Firebase Client (public)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (server / seed only - never expose to client)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Site (required in production for canonical URLs, sitemap, OG)
NEXT_PUBLIC_SITE_URL=https://sifatali.dev

# Cloudinary (server - never expose API secret to client)
CLOUDINARY_CLOUD_NAME=dfm4lnew1
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: cloud name for client-side image URL helpers
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dfm4lnew1

# GitHub API - required to avoid rate limits (403). Create at github.com/settings/tokens (no scopes).
GITHUB_TOKEN=
